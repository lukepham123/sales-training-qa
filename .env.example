# Claude API key - lay tai https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model goi AI. Khuyen nghi dung Haiku cho Q&A ngan (re hon 10 lan Sonnet).
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Cong server
PORT=3000

# Mat khau admin don gian (bao ve trang admin va cac API quan tri)
ADMIN_PASSWORD=admin123

# Trong so hybrid search (mac dinh alpha=0.4, beta=0.6)
SEARCH_ALPHA=0.4
SEARCH_BETA=0.6

# Nguong toi thieu de coi la ket qua lien quan (0.0 - 1.0)
SEARCH_MIN_SCORE=0.15

# Telegram Bot (tuy chon - de nhan thong bao khi NV hoi AI)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Gemini API (tuy chon - neu muon dung Google Gemini thay Anthropic)
# GEMINI_API_KEY=AIzaSy...

# Duong dan database (mac dinh: data/qa.db)
# DB_PATH=./data/qa.db
